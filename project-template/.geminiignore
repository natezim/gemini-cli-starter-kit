# What Gemini should NOT see when scanning this project.
# Anything listed here is INVISIBLE to Gemini — including files Gemini created.
# Keep this list TIGHT — everything Gemini produces in output/ stays visible.

# Secrets and credentials — never expose to context
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Third-party / generated noise — would bloat context
node_modules/
vendor/
.venv/
__pycache__/
dist/
build/
*.pyc
*.class

# Auto-wiped scratch — no value to Gemini after wipe
output/temp/

# Large binary formats — not useful as text context
*.zip
*.tar.gz
*.parquet
*.avro
*.log

# OS and IDE artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/

# Block credential files in context/ (but allow JSON schemas, info_schema dumps)
context/*.env
context/*.pem
context/*.key
context/*credential*.json
context/*secret*.json
context/*service-account*.json
context/*-key.json

# Everything Gemini creates in output/ stays VISIBLE:
#   output/queries/      its own SQL library
#   output/code/         its own scripts
#   output/reports/      its own analyses
#   output/data/         its own exports
#   output/audit-log.md  its own write trail
#   output/*_handoff.md  session continuity (essential for resume)
