# What Gemini should NOT see when scanning the project.
# This file controls context auto-load and file visibility.
# Anything listed here is invisible to Gemini — including files
# Gemini itself created. So keep this list TIGHT.

# Secrets and credentials — never expose to context
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Third-party / generated noise — would bloat context
node_modules/
vendor/
.venv/
__pycache__/
dist/
build/
*.pyc
*.class

# Explicitly auto-wiped scratch — no value to Gemini after wipe
output/temp/

# Large binary formats that aren't useful as text context
*.zip
*.tar.gz
*.parquet
*.avro
*.log

# OS and IDE artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/

# Prevent credentials from being dropped into context/
# (Regular JSON schemas like info_schema dumps ARE visible — only credential files blocked)
context/*.env
context/*.pem
context/*.key
context/*credential*.json
context/*secret*.json
context/*service-account*.json
context/*-key.json

# Everything Gemini creates in output/ stays visible:
#   output/queries/      its own SQL library
#   output/code/         its own scripts
#   output/reports/      its own analyses
#   output/data/         its own exports
#   output/audit-log.md  its own write trail
#   output/prompts/      your prompt history (useful for resume)
#   output/*_handoff.md  session continuity
