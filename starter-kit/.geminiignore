# Dependencies
node_modules/
vendor/
.venv/
__pycache__/

# Build output
dist/
build/
*.pyc
*.class

# Secrets and credentials — never expose to context
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Logs and data exports — may contain PII, shouldn't auto-load
output/audit-log.md
output/data/
output/prompts/
output/temp/

# NOTE: output/*_handoff.md is intentionally NOT ignored.
# /start reads the most recent handoff to resume context across sessions.
# Handoffs are still gitignored (they stay local, not in the public repo).

# Prevent credentials from being dropped into context/
# (JSON schemas like info_schema dumps are useful — only block credential files)
context/*.env
context/*.pem
context/*.key
context/*credential*.json
context/*secret*.json
context/*service-account*.json
context/*-key.json

# Large files unlikely to be useful as context
*.log
*.zip
*.tar.gz
*.parquet
*.avro

# OS and IDE artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/
