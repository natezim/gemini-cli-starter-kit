# Dependencies
node_modules/
vendor/
.venv/
__pycache__/

# Build output
dist/
build/
*.pyc
*.class

# Secrets and credentials — never expose to context
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Session log — grows over time, shouldn't be auto-loaded as context
output/session-log.md

# Large files unlikely to be useful as context
*.log
*.zip
*.tar.gz
*.parquet
*.avro

# OS and IDE artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/
