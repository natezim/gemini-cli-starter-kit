{
  "general": {
    "checkpointing": {
      "enabled": true
    },
    "sessionRetention": {
      "enabled": true,
      "maxAge": "30d",
      "maxCount": 50
    }
  },
  "context": {
    "fileName": ["GEMINI.md"],
    "includeDirectories": ["context"]
  },
  "model": {
    "chatCompression": {
      "contextPercentageThreshold": 0.2
    }
  },
  "tools": {
    "allowed": [
      "run_shell_command(git status)",
      "run_shell_command(git diff)",
      "run_shell_command(git log)",
      "read_file",
      "list_directory",
      "search_file_content",
      "glob"
    ]
  }
}
