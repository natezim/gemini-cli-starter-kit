# Credentials — NEVER commit
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Output — may contain PII, query results, sensitive data
output/data/
output/audit-log.md
output/*_handoff.md
output/prompts/
output/temp/

# Local agent state — keep template, ignore developer-personal entries
.gemini/memory/*
!.gemini/memory/MEMORY.md

# Dependencies
node_modules/
vendor/
.venv/
__pycache__/

# Build
dist/
build/

# OS/IDE
.DS_Store
Thumbs.db
.vscode/
.idea/
