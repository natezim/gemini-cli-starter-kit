# Dependencies
node_modules/
vendor/
.venv/
__pycache__/

# Build output
dist/
build/
*.pyc
*.class

# Secrets and credentials — never expose to context
.env
.env.*
*.pem
*.key
*.p12
*.pfx
secrets/
credentials/

# Scratch — temp files should never feed back as context
output/scratch/

# Large files unlikely to be useful as context
*.log
*.zip
*.tar.gz
*.parquet
*.avro

# OS and IDE artifacts
.DS_Store
Thumbs.db
.vscode/
.idea/
